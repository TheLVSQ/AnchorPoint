# AnchorPoint Production Environment Configuration
# Copy this file to docker/.env.production and fill in the values

# Django Settings
SECRET_KEY=your-secret-key-here-generate-with-python
DEBUG=False

# Database
DB_NAME=anchorpoint
DB_USER=anchorpoint
DB_PASS=change-this-to-a-secure-password
DB_HOST=db
DB_PORT=5432

# Allowed Hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,anchorpoint.bolivar.church

# CSRF Trusted Origins - must include full https:// URL
CSRF_TRUSTED_ORIGINS=https://anchorpoint.bolivar.church

# Public base URL for the cron worker that sends *scheduled* SMS/phone blasts.
# Headless jobs have no request to derive a URL from, so Twilio needs this to
# fetch phone-blast audio and post call-status callbacks. Defaults to the
# Organization Settings > Website or CSRF_TRUSTED_ORIGINS if left blank.
SITE_BASE_URL=https://anchorpoint.bolivar.church

# Days to keep phone-blast audio recordings before the daily cleanup job purges
# them from the media volume (default 30).
AUDIO_RETENTION_DAYS=30

# Enable secure cookies (Cloudflare proxies HTTPS → HTTP to your server)
REQUIRE_HTTPS=True

# Twilio (optional - for SMS and phone calls)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Google SSO (optional - enables "Sign in with Google" on the login page)
# Create a Web Application OAuth 2.0 client ID in GCP Console
# Authorized JavaScript origins: https://anchorpoint.bolivar.church
# Authorized redirect URIs: https://anchorpoint.bolivar.church/auth/google/
# GOOGLE_CLIENT_ID=

# Email (Google Workspace SMTP)
# Generate an app password: Google Account > Security > 2-Step Verification > App passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=xxxxx
EMAIL_HOST_PASSWORD=your-google-app-password-here
DEFAULT_FROM_EMAIL=xxxxxx
