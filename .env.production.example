# AnchorPoint Production Environment Configuration
# Copy this file to .env.production and fill in the values

# Django Settings
SECRET_KEY=your-secret-key-here-generate-with-python
DEBUG=False

# Database (matches docker-compose.yml defaults)
DB_NAME=anchorpoint
DB_USER=anchorpoint
DB_PASS=change-this-to-a-secure-password
DB_HOST=db
DB_PORT=5432

# Allowed Hosts (comma-separated)
# Add your Cloudflare tunnel domain here
ALLOWED_HOSTS=localhost,127.0.0.1,your-subdomain.your-domain.com

# CSRF Trusted Origins (required for Cloudflare tunnel)
# Must include the full URL with https://
CSRF_TRUSTED_ORIGINS=https://your-subdomain.your-domain.com

# Twilio (optional - for SMS and phone calls)
# Configure these in the admin UI under Organization Settings


# CloudFlare Tunnel Token
CLOUDFLARE_TUNNEL_TOKEN=your-token-here